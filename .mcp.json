{
  "mcpServers": {
    "massive": {
      "command": "/home/rchiluka/.local/bin/uvx",
      "args": [
        "--from",
        "git+https://github.com/massive-com/mcp_massive@v0.6.0",
        "mcp_massive"
      ],
      "env": {
        "MASSIVE_API_KEY": "${MASSIVE_API_KEY}",
        "HOME": "/home/rchiluka"
      }
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://${PG_USER}:${PG_PASS}@localhost:5432/postgres"
      ]
    },
    "alphavantage": {
      "command": "uvx",
      "args": ["marketdata-mcp-server", "${ALPHAVANTAGE_API_KEY}"]
    }
  }
}