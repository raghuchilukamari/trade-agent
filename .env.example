# ─────────────────────────────────────────────
# Trading Agent — Environment Configuration
# ─────────────────────────────────────────────

# ── App ──
APP_NAME=trading-agent
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── Polygon.io API ──
POLYGON_API_KEY=your_polygon_api_key_here

# ── Ollama (Local LLM) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:70b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_NUM_GPU=2
OLLAMA_NUM_THREADS=16
OLLAMA_CONTEXT_LENGTH=32768
OLLAMA_TIMEOUT=120

# ── PostgreSQL + PGVector ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=trading_agent
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=trading_agent
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# ── Data Paths ──
FLOW_DATA_DIR=/media/SHARED/trade-data/formatted
SUMMARY_OUTPUT_DIR=/media/SHARED/trade-data/summaries/docx
PRIOR_SUMMARIES_DIR=/media/SHARED/trade-data/summaries

# ── Worker Config ──
DAILY_PIPELINE_CRON=0 7 * * 1-5
MAX_CONCURRENT_AGENTS=4
AGENT_TIMEOUT_SECONDS=300

# ── UI Integration (future) ──
DASHBOARD_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── WebSocket ──
WS_HEARTBEAT_INTERVAL=30
